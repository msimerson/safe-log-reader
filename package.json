{
  "name": "safe-log-reader",
  "description": "Safe Log Reader",
  "version": "1.1.0",
  "private": false,
  "keywords": [
    "log",
    "reader",
    "tail",
    "watch"
  ],
  "homepage": "https://github.com/msimerson/safe-log-reader",
  "bugs": {
    "url": "https://github.com/msimerson/safe-log-reader/issues"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/msimerson/safe-log-reader.git"
  },
  "config": {},
  "license": "BSD-2-Clause",
  "scripts": {
    "lint": "npm install @eslint/js eslint globals && npx eslint *.js test/*.js",
    "test": "sh ./test/run.sh",
    "test:coverage": "node --test --experimental-test-coverage",
    "test:coverage:lcov": "mkdir -p coverage && node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info",
    "coverage": "NODE_ENV=cov npx istanbul cover npx mocha -- -R spec"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0"
  }
}
